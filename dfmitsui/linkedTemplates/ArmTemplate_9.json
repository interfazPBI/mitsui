{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Nombre de instancia de Data Factory",
			"defaultValue": "dfmitsui"
		},
		"INICIO_MES_properties_PIPELINE_CRESTONE_INICIO_DE_MES_parameters_Fecha_Desde": {
			"type": "string",
			"defaultValue": "dateadd(month, datediff(month, 0, DATEADD(HOUR,-5,getUTCdate())) - 1, 0)"
		},
		"INICIO_MES_properties_PIPELINE_CRESTONE_INICIO_DE_MES_parameters_Fecha_Hasta": {
			"type": "string",
			"defaultValue": "eomonth(DATEADD(HOUR,-5,getUTCdate()), -1)"
		},
		"INICIO_MES_properties_PIPELINE_CRESTONE_INICIO_DE_MES_parameters_Modulo": {
			"type": "string",
			"defaultValue": "'FACT'"
		},
		"INICIO_MES_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/2b9e0c05-41dc-4652-a897-3f88ff959ac9/resourceGroups/RG_MITSUI/providers/Microsoft.Storage/storageAccounts/mitsui"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/INICIO_MES')]",
			"type": "Microsoft.DataFactory/factories/triggers",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"runtimeState": "Started",
				"pipelines": [
					{
						"pipelineReference": {
							"referenceName": "PIPELINE_CRESTONE_INICIO_DE_MES",
							"type": "PipelineReference"
						},
						"parameters": {
							"Fecha_Desde": "[parameters('INICIO_MES_properties_PIPELINE_CRESTONE_INICIO_DE_MES_parameters_Fecha_Desde')]",
							"Fecha_Hasta": "[parameters('INICIO_MES_properties_PIPELINE_CRESTONE_INICIO_DE_MES_parameters_Fecha_Hasta')]",
							"Modulo": "[parameters('INICIO_MES_properties_PIPELINE_CRESTONE_INICIO_DE_MES_parameters_Modulo')]"
						}
					}
				],
				"type": "BlobEventsTrigger",
				"typeProperties": {
					"blobPathBeginsWith": "/dev/blobs/CRESTONE/INICIO_MES",
					"ignoreEmptyBlobs": false,
					"scope": "[parameters('INICIO_MES_properties_typeProperties_scope')]",
					"events": [
						"Microsoft.Storage.BlobCreated"
					]
				}
			},
			"dependsOn": []
		}
	]
}